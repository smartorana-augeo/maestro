# User Information
YOUR_NAME="Your Name"
YOUR_EMAIL="your.github.email@company.com"

# Atlassian (Jira + Confluence)
# Generate token: https://id.atlassian.com/manage-profile/security/api-tokens
ATLASSIAN_EMAIL="your.email@company.com"
ATLASSIAN_API_TOKEN="your-atlassian-api-token"
ATLASSIAN_DOMAIN="yourcompany.atlassian.net"

# MCP Context7
# Setup: https://github.com/upstash/context7?tab=readme-ov-file#installation
# Generate token: https://context7.com/dashboard
CONTEXT7_API_KEY="your-context7-api-key"

# CircleCI
# Generate token: https://app.circleci.com/settings/user/tokens
CIRCLECI_TOKEN="your-circleci-token"

# Grafana
# Retrieve from 1Password: "Grafana claude-code-integration-readonly API Key"
GRAFANA_TOKEN="your-grafana-api-token"

# Tempo (Jira Time Tracking)
# Generate token: https://augeomarketing.atlassian.net/plugins/servlet/ac/io.tempo.jira/tempo-app#!/configuration/api-integration
TEMPO_API_TOKEN="your-tempo-api-token"

# TestRail
# Generate token: https://augeo.testrail.io/index.php?/mysettings
TESTRAIL_EMAIL="your.testrail.email@company.com"
TESTRAIL_API_KEY="your-testrail-api-key"
TESTRAIL_DOMAIN="yourcompany.testrail.io"
